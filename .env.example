# Symphony Environment Configuration
#
# ⚠️  SECURITY WARNING: NEVER COMMIT API KEYS TO VERSION CONTROL
# 1. Copy this file: cp .env.example .env
# 2. Add your actual API keys to .env (not this file)
# 3. Verify .env is in .gitignore
# 4. See SECURITY.md for complete security guide

# Model Provider Configuration
# Options: anthropic, openai, gemini, mock
MODEL_PROVIDER=mock

# API Keys (obtain from respective providers)
# Anthropic Claude: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here
# OpenAI GPT: https://platform.openai.com/
OPENAI_API_KEY=your_openai_key_here
# Google Gemini: https://makersuite.google.com/
GOOGLE_API_KEY=your_google_key_here

# FHIR Server Configuration
SOURCE_FHIR_BASE=https://hapi.fhir.org/baseR4
HAPI_BASE=http://hapi:8080/fhir

# Backend Configuration
BACKEND_URL=http://api:8000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Development vs Production
# Use different API keys for different environments
# Development: Lower rate limits, test keys
# Production: Production keys with appropriate limits
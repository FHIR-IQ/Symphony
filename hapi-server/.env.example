# Symphony HAPI FHIR Server Environment Configuration

# Server Configuration
SERVER_PORT=8080
HAPI_FHIR_SERVER_ADDRESS=https://your-app.railway.app

# Database Configuration (PostgreSQL for production)
DATABASE_URL=postgresql://user:password@host:5432/symphony_fhir
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_secure_password
DATABASE_DRIVER=org.postgresql.Driver
HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# Alternative: H2 in-memory database (development only)
# DATABASE_URL=jdbc:h2:mem:testdb
# DATABASE_USERNAME=
# DATABASE_PASSWORD=
# DATABASE_DRIVER=org.h2.Driver
# HIBERNATE_DIALECT=org.hibernate.dialect.H2Dialect

# Logging
SPRING_PROFILES_ACTIVE=production

# Security (set to true for production)
HAPI_FHIR_SECURITY_ENABLED=false

# Custom Branding
SYMPHONY_BRANDING_NAME=Symphony FHIR Server
SYMPHONY_BRANDING_DESCRIPTION=HAPI FHIR Server for Symphony AI Clinical Summaries
SYMPHONY_BRANDING_ORGANIZATION=Symphony AI
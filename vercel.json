{
  "functions": {
    "frontend/app/**": {
      "runtime": "@vercel/next@4.3.7"
    }
  },
  "builds": [
    {
      "src": "frontend/next.config.js",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_DEMO_MODE": "true",
    "NEXT_PUBLIC_API_BASE_URL": ""
  }
}
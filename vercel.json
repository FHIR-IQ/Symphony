{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/.next",
  "installCommand": "cd frontend && npm install",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_HAPI_SERVER_URL": "https://symphony-hapi.railway.app",
    "NEXT_PUBLIC_HAPI_BASE_PATH": "/fhir",
    "NEXT_PUBLIC_HAPI_BASE_URL": "https://symphony-hapi.railway.app/fhir",
    "HAPI_BASE_URL": "https://symphony-hapi.railway.app/fhir",
    "NEXT_PUBLIC_USE_REAL_API": "true",
    "NEXT_PUBLIC_HAPI_WEB_URL": "https://symphony-hapi.railway.app",
    "NEXT_PUBLIC_ENABLE_FHIR_VIEWER": "true",
    "NEXT_PUBLIC_ENABLE_FHIR_VALIDATION": "true"
  }
}